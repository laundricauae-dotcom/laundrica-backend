    "uuid": "^14.0.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "eslint": "^10.6.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.0"
  },
  "nodemonConfig": {
    "ignore": [
      "node_modules",
      "data",
      "logs"
    ],
    "watch": [
      "*.js",
      "config/**/*.js",
      "controllers/**/*.js",
      "models/**/*.js",
      "routes/**/*.js",
      "services/**/*.js",
      "middleware/**/*.js",
      "utils/**/*.js",
      "workers/**/*.js",
      "cache/**/*.js"
    ],
    "ext": "js,json"
  }
