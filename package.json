  "dependencies": {
    "@redis-ai/langcache": "^0.12.0",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "geoip-lite": "^2.0.3",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.4",
    "open": "^11.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
